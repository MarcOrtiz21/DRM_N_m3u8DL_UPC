{
  "manifest_version": 3,
  "name": "ASES DRM Extractor",
  "version": "1.0",
  "description": "Extrae automáticamente el iframe de vídeo de ASES Academia para descarga offline",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.asesacademia.com/*",
    "https://asesacademia.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.asesacademia.com/campus/*",
        "https://asesacademia.com/campus/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
